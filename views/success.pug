doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title Submission Successful
    style.
      body { font-family: Arial, sans-serif; background-color: #fdfdfc; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; }
      .container { text-align: center; background: white; padding: 40px; border-radius: 8px; box-shadow: 0 10px 25px rgba(0,0,0,0.05); border: 1px solid #d1d5db; }
      h1 { color: #059669; }
      .btn { display: inline-block; margin-top: 20px; padding: 10px 20px; background-color: #2563eb; color: white; text-decoration: none; border-radius: 4px; font-weight: bold; }
  body
    .container
      h1 ✓ Submission Successful
      p The Criminal Risk Assessment Request has been securely recorded.
      a.btn(href="/form") Submit Another Request
      br
      br
      a(href="/logout" style="color: #6b7280; font-size: 0.9rem;") Log out